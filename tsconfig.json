{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["astro/client"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "astro.config.mjs", "vite-env.d.ts"],
  "exclude": ["dist", "node_modules"]
}
